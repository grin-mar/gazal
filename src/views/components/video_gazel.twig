{% set video_gaz = component %}

{% set video_gaz = component %}

<section class="s-block s-block--video mt-16 {{ video_gaz.sec_width == 'full' ? 'video-fullwidth s-block--full-bg' : '' }} {{ video_gaz['txt_class'] }}">

  <div class="video-fullwidth__container {{ video_gaz.sec_width == 'Boxed' ? 'container' : '' }}">

    <div
      class="videoWrapper"
      data-video-url="{{ video_gaz.urlvi_d|default('')|trim }}"
      data-poster-url="{{ video_gaz.vid_mage|default('')|trim }}"
    >

      <div class="video-inner"></div>

      <button type="button" class="video-toggle" aria-label="تشغيل الفيديو">
        <span class="icon icon-play" aria-hidden="true"></span>
      </button>

      <div class="video-msg" hidden></div>

    </div>

  </div>

</section>

{% block stylevideo %}
<style>
  .video-fullwidth {
    width: 100vw;
    max-width: 100%;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
  .video-fullwidth__container {
    max-width: none !important;
    width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }
.videoWrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #000;
  aspect-ratio: 16/9;
  border-radius: 16px;
}
  .bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .video-toggle {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 74px;
    height: 74px;
    border-radius: 999px;
    border: 0;
    background: rgba(0, 0, 0, 0.45);
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 2;
    backdrop-filter: blur(2px);
    touch-action: manipulation;
  }
  .video-toggle:hover {
    background: rgba(0, 0, 0, 0.55);
  }
  .icon-play {
    width: 0;
    height: 0;
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
    border-left: 18px solid #fff;
    margin-left: 3px;
  }
  .icon-pause {
    width: 18px;
    height: 18px;
    position: relative;
  }
  .icon-pause:before,
  .icon-pause:after {
    content: "";
    position: absolute;
    top: 0;
    width: 6px;
    height: 18px;
    background: #fff;
    border-radius: 2px;
  }
  .icon-pause:before {
    left: 0;
  }
  .icon-pause:after {
    right: 0;
  }
  .videoWrapper.is-playing .video-toggle {
    opacity: 0.15;
  }
  .video-msg {
    position: absolute;
    inset: auto 12px 12px 12px;
    z-index: 3;
    padding: 10px 12px;
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 13px;
    direction: rtl;
    text-align: right;
  }

  @media (max-width: 767px) {
    .videoWrapper {
      height: 752px;
      aspect-ratio: auto;
    }
  }
  @media (max-width: 767px) {

  .videoWrapper{
    height: 420px;
    aspect-ratio:auto;
  }

}
.video-inner,
.video-inner iframe,
.video-inner video{
  width:100%;
  height:100%;
}

</style>
{% endblock %} 
{% block scriptvideo %}

<script>
(function () {

  function getYoutubeId(url) {

    const regExp =
      /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;

    const match = url.match(regExp);

    return (match && match[2].length === 11)
      ? match[2]
      : null;
  }

  function initVideoBlock(wrapper) {

    const inner = wrapper.querySelector(".video-inner");
    const btn = wrapper.querySelector(".video-toggle");
    const msg = wrapper.querySelector(".video-msg");

    if (!inner || !btn) return;

    const url =
      (wrapper.getAttribute("data-video-url") || "").trim();

    const poster =
      (wrapper.getAttribute("data-poster-url") || "").trim();

    if (!url) {
      msg.hidden = false;
      msg.textContent = "⚠️ رابط الفيديو غير موجود";
      return;
    }

    const youtubeId = getYoutubeId(url);

    /* =========================
       YOUTUBE
    ========================== */

    if (youtubeId) {

      inner.innerHTML = `
        <iframe
          class="bg-video"
          src="https://www.youtube.com/embed/${youtubeId}?enablejsapi=1&rel=0"
          title="YouTube video"
          frameborder="0"
          allow="autoplay; encrypted-media"
          allowfullscreen>
        </iframe>
      `;

      btn.addEventListener("click", function () {

        const iframe = inner.querySelector("iframe");

        iframe.src =
          "https://www.youtube.com/embed/" +
          youtubeId +
          "?autoplay=1&rel=0";

        wrapper.classList.add("is-playing");
      });

      return;
    }

    /* =========================
       MP4
    ========================== */

    inner.innerHTML = `
      <video
        class="bg-video"
        playsinline
        muted
        loop
        preload="metadata"
        poster="${poster}"
        controlslist="nodownload noplaybackrate"
      ></video>
    `;

    const video = inner.querySelector("video");

    video.src = url;

    function setPlaying(state){

      wrapper.classList.toggle("is-playing", state);

      const icon = btn.querySelector(".icon");

      icon.className =
        "icon " + (state ? "icon-pause" : "icon-play");
    }

    btn.addEventListener("click", function () {

      if(video.paused){

        video.play();

        setPlaying(true);

      } else {

        video.pause();

        setPlaying(false);
      }

    });

    video.addEventListener("pause", function () {
      setPlaying(false);
    });

    video.addEventListener("play", function () {
      setPlaying(true);
    });

  }

  document.addEventListener("DOMContentLoaded", function () {

    const blocks =
      document.querySelectorAll(".videoWrapper");

    blocks.forEach(initVideoBlock);

  });

})();
</script>
{% endblock %}