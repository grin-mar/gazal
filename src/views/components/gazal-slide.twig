<section class="test-link-slider">

  <div class="container">

    <h2>
      {{ component.test_title }}
    </h2>

    {% if component.test_link %}

      <a
        href="{{ component.test_link.url }}"
        class="test-btn"
      >
        افتح الرابط
      </a>

      <pre>
{{ component.test_link|json_encode(constant('JSON_PRETTY_PRINT')) }}
      </pre>

    {% endif %}

  </div>

</section>