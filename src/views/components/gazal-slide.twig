{% set el_slide = component %}

<section class="s-block s-block--default home-slider {{ el_slide.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ el_slide.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="home-main-slider"
      auto-play="{{ el_slide.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ el_slide.TIME1 > 0 and el_slide.TIME1 < 100 ? el_slide.TIME1 * 1000 : el_slide.TIME1 }}"
      pagination
      type="fullwidth"
      dir="rtl"
      show-controls="true"
      slider-config='{
        "speed":700,
        "loop":true,
        "allowTouchMove":true
      }'>

      <div slot="items">

        {% for banner in el_slide.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex {{ banner.text_pos }}">

            <div
              class="home-slide__text {{ el_slide.blur2 ? 'has-blur' : '' }}"
              {% if el_slide.blur2 %}
              style="background: {{ el_slide.background22 }}80;"
              {% endif %}
            >

              {% if banner.banner_main %}
              <h3
                class="home-slide__title"
                style="
                  color:{{ el_slide.main_color }};
                  font-size:{{ el_slide.pc_main_1 }}px;
                "
              >

                {% set words = banner.banner_main|split(' ') %}
                {% set last = words|last %}
                {% set rest = words|slice(0, words|length - 1)|join(' ') %}

                {{ rest }}

                <span style="color:{{ el_slide.special_word }}">
                  {{ last }}
                </span>

              </h3>
              {% endif %}

              {% if banner.banne_des %}
              <p
                class="home-slide__body"
                style="
                  color:{{ el_slide.des_color }};
                  font-size:{{ el_slide.pc_des }}px;
                "
              >
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a
                href="{{ banner.but_url }}"
                class="home-slide__btn"
                style="
                  background:{{ el_slide.burton_back }};
                  color:{{ el_slide.button_color }};
                "
              >
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>

        {% endfor %}

      </div>

    </salla-slider>

  </div>

</section>

{% block styleslider %}
<style>

.home-slider{
  position:relative;
  overflow:hidden;
}

.home-slide{
  position:relative;
  min-height:650px;
}

.home-slide__img{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}

.home-slider__content{
  position:absolute;
  inset:0;
  display:flex;
  padding:40px;
  z-index:2;
  pointer-events:none;
}

.home-slide__text{
  width:fit-content;
  max-width:min(650px,90%);
  min-width:280px;
  display:flex;
  flex-direction:column;
  gap:16px;
  padding:26px;
  border-radius:18px;
  pointer-events:auto;
  margin:20px;
}

.has-blur{
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,0.08);
}

.home-slide__title{
  font-weight:700;
  line-height:1.4;
  word-break:break-word;
  margin:0;
}

.home-slide__body{
  line-height:1.8;
  word-break:break-word;
  margin:0;
}

.home-slide__btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:fit-content;
  min-width:160px;
  padding:14px 28px;
  border-radius:12px;
  text-decoration:none;
  transition:0.3s ease;
  font-weight:600;
}

.home-slide__btn:hover{
  transform:translateY(-2px);
  opacity:.9;
}

.home-slider .swiper-button-next,
.home-slider .swiper-button-prev{
  width:46px;
  height:46px;
  border-radius:50%;
  background:rgba(0,0,0,.35);
  backdrop-filter:blur(6px);
  -webkit-backdrop-filter:blur(6px);
  color:#fff;
}

.home-slider .swiper-button-next:after,
.home-slider .swiper-button-prev:after{
  font-size:16px;
  font-weight:700;
}

.home-slider .swiper-pagination{
  bottom:24px !important;
}

.home-slider .swiper-pagination-bullet{
  width:12px;
  height:12px;
  opacity:1;
  background:#fff;
}

{% if el_slide.shkl_aalamat_altnql == 'line' %}

.home-slider .swiper-pagination-bullet{
  width:45px;
  height:5px;
  border-radius:999px;
}

{% elseif el_slide.shkl_aalamat_altnql == 'square' %}

.home-slider .swiper-pagination-bullet{
  border-radius:4px;
}

{% else %}

.home-slider .swiper-pagination-bullet{
  border-radius:50%;
}

{% endif %}

.swiper-slide-active .home-slide__title{
  animation:fadeRight .8s ease both;
}

.swiper-slide-active .home-slide__body{
  animation:fadeRight .8s .2s ease both;
}

.swiper-slide-active .home-slide__btn{
  animation:fadeRight .8s .4s ease both;
}

@keyframes fadeRight{

  0%{
    transform:translateX(50px);
    opacity:0;
  }

  100%{
    transform:translateX(0);
    opacity:1;
  }
}

@media(max-width:768px){

  .home-slide{
    min-height:340px;
  }

  .home-slider__content{
    padding:16px;
  }

  .home-slide__text{
    min-width:auto;
    max-width:100%;
    padding:18px;
    margin:10px;
  }

  .home-slide__title{
    font-size:{{ el_slide.mob_main }}px !important;
  }

  .home-slide__body{
    font-size:{{ el_slide.mob_des }}px !important;
  }

  .home-slide__btn{
    width:100%;
    min-width:unset;
    padding:12px 18px;
  }

}

</style>
{% endblock %}

{% block scriptslider %}
<script>

document.addEventListener('DOMContentLoaded', function(){

  const slider = document.querySelector('#home-main-slider');

  if(!slider) return;

  function initSlider(){

    if(!slider.swiper){
      setTimeout(initSlider,200);
      return;
    }

    const swiper = slider.swiper;

    let delay = Number({{ el_slide.TIME1|default(5) }});

    if(delay > 0 && delay < 100){
      delay = delay * 1000;
    }

    swiper.params.autoplay = {
      delay: delay,
      disableOnInteraction:false
    };

    swiper.autoplay.start();

    swiper.update();
  }

  initSlider();

});

</script>
{% endblock %}
