{% set el_slide = component %}
{% set slider_id = 'home-main-slider-' ~ position %}
{% set nav_shape = el_slide.shkl_aalamat_altnql.selected[0].value|default('cricle') %}

<section class="s-block s-block--default home-slider {{ el_slide.sec_width.selected[0].value == 'full' ? 's-block--full-bg' : '' }} {{ el_slide.txt_class }}">

  <div class="{{ el_slide.sec_width.selected[0].value == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="{{ slider_id }}"
      auto-play
      pagination
      type="fullwidth"
      show-controls="true"

  slider-config="{{ {

  loop: true,
  speed: 700,
  allowTouchMove: true,

  autoplay: {
    delay: ((el_slide.TIME1 ?: 5) * 1000)|round,
    disableOnInteraction: false
  },

  pagination: {
    el: '#' ~ slider_id ~ ' .swiper-pagination',
    clickable: true
  }

}|json_encode|e('html_attr') }}"
    >

      <div slot="items">

        {% for banner in el_slide.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ?: banner.banner_mg_big %}

        <div class="swiper-slide home-slide" id="slide-{{ position }}-{{ loop.index }}">

          <a href="{{ banner.but_url }}" class="home-slide__link">

            <picture>

              <source
                media="(max-width:768px)"
                srcset="{{ mob }}"
              >

              <img
                src="{{ img }}"
                class="home-slide__img"
                loading="{{ loop.first ? 'eager' : 'lazy' }}"
                fetchpriority="{{ loop.first ? 'high' : 'low' }}"
                decoding="async"
                draggable="false"
              >

            </picture>

            <div class="home-slider__content flex {{ el_slide.text_pos.selected[0].value ?: 'items-center justify-center text-center' }}">

              <div
                class="home-slide__text {{ el_slide.blur2 ? 'has-blur' : '' }}"
                {% if el_slide.blur2 %}
                style="background: {{ el_slide.background22 }}80;"
                {% endif %}
              >

                {% if banner.banner_main %}

                <h3
                  class="home-slide__title"
                  style="
                    color:{{ el_slide.main_color }};
                    font-size:{{ el_slide.pc_main_1 }}px;
                  "
                >

                  {% set words = banner.banner_main|split(' ') %}
                  {% set last = words|last %}
                  {% set rest = words|slice(0, words|length - 1)|join(' ') %}

                  {{ rest }}

                  <span style="color:{{ el_slide.special_word }}">
                    {{ last }}
                  </span>

                </h3>

                {% endif %}

                {% if banner.banne_des %}

                <p
                  class="home-slide__body"
                  style="
                    color:{{ el_slide.des_color }};
                    font-size:{{ el_slide.pc_des }}px;
                  "
                >
                  {{ banner.banne_des }}
                </p>

                {% endif %}

                {% if banner.banner_button %}

                <span
                  class="home-slide__btn"
                  style="
                    background:{{ el_slide.burton_back }};
                    color:{{ el_slide.button_color }};
                  "
                >
                  {{ banner.banner_button }}
                </span>

                {% endif %}

              </div>

            </div>

          </a>

        </div>

        {% endfor %}

      </div>

    </salla-slider>

  </div>

</section>

{% block styleslider %}
<style>

.home-slider{
  position:relative;
  overflow:hidden;
}

.home-slide{
  position:relative;
  min-height:650px;
}

{% if el_slide.height1 %}
.home-slide{
  min-height:auto;
}
{% endif %}

.home-slide__link{
  position:relative;
  display:block;
  width:100%;
  height:100%;
  min-height:inherit;
}

.home-slide__img{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}

.home-slider__content{
  position:absolute;
  inset:0;
  display:flex;
  padding:40px;
  z-index:2;
}

.home-slide__text{
  width:fit-content;
  max-width:min(650px,90%);
  min-width:280px;
  display:flex;
  flex-direction:column;
  gap:16px;
  padding:26px;
  border-radius:18px;
  margin:20px;
}

.has-blur{
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,0.08);
}

.home-slide__title{
  font-weight:700;
  line-height:1.4;
  word-break:break-word;
  margin:0;
}

.home-slide__body{
  line-height:1.8;
  word-break:break-word;
  margin:0;
}

.home-slide__btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:fit-content;
  min-width:160px;
  padding:14px 28px;
  border-radius:12px;
  transition:.3s ease;
  font-weight:600;
}

.home-slide__btn:hover{
  transform:translateY(-2px);
  opacity:.9;
}

#{{ slider_id }} .swiper-button-next,
#{{ slider_id }} .swiper-button-prev{
  width:46px;
  height:46px;
  border-radius:50%;
  background:rgba(0,0,0,.35);
  backdrop-filter:blur(6px);
  -webkit-backdrop-filter:blur(6px);
  color:#fff;
}

#{{ slider_id }} .swiper-button-next:after,
#{{ slider_id }} .swiper-button-prev:after{
  font-size:16px;
  font-weight:700;
}

#{{ slider_id }} .swiper-pagination{
  bottom:24px !important;
}

#{{ slider_id }} .swiper-pagination-bullet{
  width:12px;
  height:12px;
  background:#fff;
  opacity:.35;
  transition:.3s ease;
}

#{{ slider_id }} .swiper-pagination-bullet-active{
  opacity:1;
  transform:scale(1.12);
  background:{{ el_slide.main_color }};
}

{% if nav_shape == 'line' %}

#{{ slider_id }} .swiper-pagination-bullet{
  width:45px;
  height:5px;
  border-radius:999px;
}

{% elseif nav_shape == 'square' %}

#{{ slider_id }} .swiper-pagination-bullet{
  border-radius:4px;
}

{% else %}

#{{ slider_id }} .swiper-pagination-bullet{
  border-radius:50%;
}

{% endif %}

.swiper-slide-active .home-slide__title{
  animation:fadeRight .8s ease both;
}

.swiper-slide-active .home-slide__body{
  animation:fadeRight .8s .2s ease both;
}

.swiper-slide-active .home-slide__btn{
  animation:fadeRight .8s .4s ease both;
}

@keyframes fadeRight{

  0%{
    transform:translateX(50px);
    opacity:0;
  }

  100%{
    transform:translateX(0);
    opacity:1;
  }

}

@media(max-width:768px){

  .home-slide{
    min-height:340px;
  }

  .home-slider__content{
    padding:16px;
  }

  .home-slide__text{
    min-width:auto;
    max-width:100%;
    padding:18px;
    margin:10px;
  }

  .home-slide__title{
    font-size:{{ el_slide.mob_main }}px !important;
  }

  .home-slide__body{
    font-size:{{ el_slide.mob_des }}px !important;
  }

  .home-slide__btn{
    width:100%;
    min-width:unset;
    padding:12px 18px;
  }

}

</style>
{% endblock %}

{% block scriptslider %}
<script>

document.addEventListener('DOMContentLoaded', function(){

  const slider = document.querySelector('#{{ slider_id }}');

  if(!slider) return;

  function initSlider(){

    if(!slider.swiper){
      setTimeout(initSlider,200);
      return;
    }

    slider.swiper.update();

  }

  initSlider();

});

</script>
{% endblock %}
