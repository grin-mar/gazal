<section class="s-block s-block--default home-slider {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="home-main-slider"
      auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ component.TIME1 > 0 and component.TIME1 < 100 ? component.TIME1 * 1000 : component.TIME1 }}"
      pagination
      type="carousel"
      dir="rtl"
      show-controls="true">

      <div slot="items">

        {% for banner in component.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex {{ component.text_pos }}">

            <div
              class="home-slide__text {{ component.blur2 ? 'has-blur' : '' }}"
              {% if component.blur2 %}
              style="background: rgba(0,0,0,0.35);"
              {% endif %}
            >

              {% if banner.banner_main %}
              <h3
                class="home-slide__title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;"
              >
                {{ banner.banner_main }}
              </h3>
              {% endif %}

              {% if banner.banne_des %}
              <p
                class="home-slide__body"
                style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;"
              >
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a
                href="{{ banner.rabt_zr }}"
                class="home-slide__btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};"
              >
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>

        {% endfor %}

      </div>

    </salla-slider>

  </div>

</section>

{% block styleslider %}
<style>

.home-slider{
  position:relative;
  overflow:hidden;
}

.home-slide{
  position:relative;
  min-height:650px;
}

.home-slide__img{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}

.home-slider__content{
  position:absolute;
  inset:0;
  display:flex;
  padding:40px;
  pointer-events:none;
}

.home-slide__text{
  width:fit-content;
  max-width:700px;
  min-width:280px;
  display:flex;
  flex-direction:column;
  gap:16px;
  pointer-events:auto;
  margin:20px;
}

.has-blur{
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
  padding:24px;
  border-radius:16px;
}

.home-slide__title{
  line-height:1.4;
  word-break:break-word;
  font-weight:700;
}

.home-slide__body{
  line-height:1.7;
  word-break:break-word;
}

.home-slide__btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:fit-content;
  min-width:160px;
  height:48px;
  padding:0 24px;
  border-radius:10px;
  text-decoration:none;
  transition:.3s;
}

.home-slide__btn:hover{
  opacity:.9;
  transform:translateY(-2px);
}

.home-slider .swiper-button-next,
.home-slider .swiper-button-prev{
  width:42px;
  height:42px;
  border-radius:50%;
  background:rgba(0,0,0,.35);
  color:#fff;
}

.home-slider .swiper-button-next:after,
.home-slider .swiper-button-prev:after{
  font-size:16px;
}

.home-slider .swiper-pagination{
  bottom:20px !important;
}

.home-slider .swiper-pagination-bullet{
  width:12px;
  height:12px;
  opacity:1;
  background:#fff;
}

.home-slider .swiper-pagination-bullet-active{
  width:32px;
  border-radius:999px;
}

@media(max-width:768px){

  .home-slide{
    min-height:320px;
  }

  .home-slider__content{
    padding:14px;
  }

  .home-slide__text{
    max-width:100%;
    min-width:unset;
    margin:0;
  }

  .has-blur{
    padding:16px;
  }

  .home-slide__title{
    font-size:{{ component.mob_main }}px !important;
  }

  .home-slide__body{
    font-size:{{ component.mob_des }}px !important;
  }

}

</style>
{% endblock %}

{% block scriptslider %}
<script>

document.addEventListener('DOMContentLoaded', function(){

  const slider = document.querySelector('#home-main-slider');

  if(!slider) return;

  const initSlider = () => {

    if(!slider.swiper){
      setTimeout(initSlider, 200);
      return;
    }

    const swiper = slider.swiper;

    let delay = Number({{ component.TIME1|default(0) }});

    if(delay > 0 && delay < 100){
      delay = delay * 1000;
    }

    if(delay > 0){

      swiper.params.autoplay = {
        delay: delay,
        disableOnInteraction:false
      };

      if(swiper.autoplay){
        swiper.autoplay.start();
      }

    }

    swiper.update();

  };

  initSlider();

});

</script>
{% endblock %}
