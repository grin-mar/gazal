<section class="s-block s-block--counter" dir="rtl">

    {% set target = (section.settings.counterdate ?? component.counterdate ?? '')|default('')|trim %}
    {% set mainText = (section.settings.maintextcount ?? component.maintextcount ?? '')|default('')|trim %}
    {% set subText = (section.settings.subtextcount ?? component.subtextcount ?? '')|default('')|trim %}
    {% set imgSrc = (section.settings.imagecount ?? component.imagecount ?? '')|default('')|trim %}

    {% set itemBg = (section.settings['item-bac'] ?? attribute(component,'item-bac') ?? '#bdc5c7') %}
    {% set mainColor = (section.settings['main-txt-color'] ?? attribute(component,'main-txt-color') ?? '#000') %}
    {% set subColor = (section.settings['sub-txt-color'] ?? attribute(component,'sub-txt-color') ?? '#000') %}

    {% set buttonUrl = section.settings.buttonurl1 ?? attribute(component,'buttonurl1') ?? '' %}
    {% set buttonText = section.settings.buttonname ?? attribute(component,'buttonname') ?? '' %}
    {% set btnBg = section.settings.backbutton ?? attribute(component,'backbutton') ?? '#004956' %}
    {% set btnColor = section.settings.buttoncolor ?? attribute(component,'buttoncolor') ?? '#ffffff' %}

    {% set buttonUrl = buttonUrl|default('')|trim %}
    {% set buttonText = buttonText|default('')|trim %}

    <div class="counter-wrap s-card rounded-md {{ imgSrc ? '' : 'no-image' }}" data-countdown="{{ target }}"
        style="background: {{ itemBg }};">

        <div class="counter-left">

            <div class="counter-cells">
                <div class="cell">
                    <div class="num js-days">00</div>
                    <div class="lbl">أيام</div>
                </div>
                <div class="cell">
                    <div class="num js-hours">00</div>
                    <div class="lbl">ساعات</div>
                </div>
                <div class="cell">
                    <div class="num js-mins">00</div>
                    <div class="lbl">دقائق</div>
                </div>
                <div class="cell">
                    <div class="num js-secs">00</div>
                    <div class="lbl">ثواني</div>
                </div>
            </div>

            {% if mainText %}
            <h3 class="counter-title" style="color: {{ mainColor }};">{{ mainText }}</h3>
            {% endif %}

            {% if subText %}
            <p class="counter-sub" style="color: {{ subColor }};">{{ subText }}</p>
            {% endif %}

            <div class="counter-msg" hidden></div>

            {% if buttonUrl and buttonText %}
            <a href="{{ buttonUrl }}" class="counter-btn" style="background:{{ btnBg }};color:{{ btnColor }};">
                {{ buttonText }}
            </a>
            {% endif %}

        </div>

        {% if imgSrc %}
        <div class="counter-right">
            <img class="counter-image" src="{{ imgSrc }}" alt="" loading="lazy" />
        </div>
        {% endif %}

    </div>

</section>

{% block stylecounter %}
<style>
    .s-block--counter {
        padding: 48px 0;
    }

    .counter-wrap {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: row-reverse;
        overflow: hidden;
        border-radius: 16px;
    }

    .counter-wrap.no-image {
        justify-content: center;
    }

    .counter-wrap.no-image .counter-left {
        width: 100%;
        align-items: center;
        text-align: center;
    }

    .counter-right {
        width: 420px;
        flex: 0 0 420px;
    }

    .counter-image {
        width: 100%;
        height: 100%;
        min-height: 460px;
        object-fit: cover;
        display: block;
    }

    .counter-left {
        flex: 1;
        padding: 56px 64px;
        display: flex;
        gap: 28px;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
    }

    .counter-cells {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    .cell {
        width: 130px;
        height: 150px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(6px);
    }

    .cell .num {
        font-size: 48px;
        font-weight: 800;
        letter-spacing: 1px;
        line-height: 1;
    }

    .cell .lbl {
        font-size: 14px;
        opacity: 0.8;
        margin-top: 6px;
    }

    .counter-title {
        font-size: 40px;
        font-weight: 700;
        line-height: 1.4;
        text-align: right;
    }

    .counter-sub {
        font-size: 17px;
        line-height: 1.6;
        opacity: 0.9;
        text-align: right;
    }

    .counter-btn {
        width: fit-content;
        min-width: 180px;
        padding: 12px 22px;
        border-radius: 10px;
        font-size: 15px;
        transition: 0.3s;
    }

    .counter-btn:hover {
        transform: translateY(-2px);
        opacity: 0.9;
    }

    @media (max-width: 992px) {

        .counter-title {
            font-size: 26px;
            text-align: center;
        }

        .counter-sub {
            text-align: center;
        }

        .cell {
            width: 90px;
            height: 100px;
        }

        .cell .num {
            font-size: 30px;
        }
    }

    @media (max-width: 767px) {

        .counter-wrap {
            flex-direction: column-reverse;
            padding: 16px;
        }

        .counter-left {
            align-items: center;
            padding: 28px 16px;
        }

        .counter-right {
            width: 100%;
        }

        .counter-image {
            min-height: auto;
        }

        .counter-title,
        .counter-sub {
            text-align: center;
        }

        .cell {
            width: 70px;
            height: 80px;
        }

        .cell .num {
            font-size: 24px;
        }

        .cell .lbl {
            font-size: 12px;
        }

        .counter-btn {
            width: 100%;
            max-width: 260px;
            margin-inline: auto;
        }
    }
</style>
{% endblock %}

{% block scriptcounter %}
<script>
    (function () {
        function pad2(n) { return String(n).padStart(2, "0") }
        function initCountdown(wrap) {
            var targetStr = wrap.getAttribute("data-countdown"); if (!targetStr) return;
            var target = new Date(targetStr); if (isNaN(target)) return;
            var d = wrap.querySelector(".js-days"),
                h = wrap.querySelector(".js-hours"),
                m = wrap.querySelector(".js-mins"),
                s = wrap.querySelector(".js-secs");
            function tick() {
                var now = new Date(), diff = target - now;
                if (diff <= 0) { d.textContent = h.textContent = m.textContent = s.textContent = "00"; clearInterval(t); return; }
                var sec = Math.floor(diff / 1000), days = Math.floor(sec / 86400); sec %= 86400;
                var hours = Math.floor(sec / 3600); sec %= 3600;
                var mins = Math.floor(sec / 60), secs = sec % 60;
                d.textContent = days;
                h.textContent = pad2(hours);
                m.textContent = pad2(mins);
                s.textContent = pad2(secs);
            }
            tick(); var t = setInterval(tick, 1000);
        }
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".counter-wrap[data-countdown]").forEach(initCountdown);
        });
    })();
</script>
{% endblock %}

<h2 style="background:#114e6d; padding:6px 12px; border-radius:6px; display:inline-block;">
    عرض خاص
</h2>


