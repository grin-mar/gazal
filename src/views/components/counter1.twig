<section class="s-block s-block--counter" dir="rtl">
    {% set target = (section.settings.counterdate ?? component.counterdate ?? '')
    | default('') | trim %}

    {% set mainText = (section.settings.maintextcount ?? component.maintextcount ?? '')
    | default('') | trim %}

    {% set subText = (section.settings.subtextcount ?? component.subtextcount ?? '')
    | default('') | trim %}

    {% set imgSrc = (section.settings.imagecount ?? component.imagecount ?? '')
    | default('') | trim %}

    <div class="counter-wrap" data-countdown="{{ target }}">
        <div class="counter-left">
            <div class="counter-cells">
                <div class="cell">
                    <div class="num js-days">00</div>
                    <div class="lbl">أيام</div>
                </div>
                <div class="cell">
                    <div class="num js-hours">00</div>
                    <div class="lbl">ساعات</div>
                </div>
                <div class="cell">
                    <div class="num js-mins">00</div>
                    <div class="lbl">دقائق</div>
                </div>
                <div class="cell">
                    <div class="num js-secs">00</div>
                    <div class="lbl">ثواني</div>
                </div>
            </div>

            {% if mainText %}
            <h3 class="counter-title">{{ mainText }}</h3>
            {% endif %}

            {% if subText %}
            <p class="counter-sub">{{ subText }}</p>
            {% endif %}

            <div class="counter-msg" hidden></div>

            {% set buttonUrl = section.settings.buttonurl1 ??
            attribute(section.settings,'buttonurl1') ??
            section.settings.get('buttonurl1') ??
            component.buttonurl1 ??
            attribute(component,'buttonurl1') ??
            component.get('buttonurl1') ?? '' %}

            {% set buttonText = section.settings.buttonname ??
            attribute(section.settings,'buttonname') ??
            section.settings.get('buttonname') ??
            component.buttonname ??
            attribute(component,'buttonname') ??
            component.get('buttonname') ?? '' %}

            {% set btnBg = section.settings.backbutton ??
            attribute(section.settings,'backbutton') ??
            section.settings.get('backbutton') ??
            component.backbutton ??
            attribute(component,'backbutton') ??
            component.get('backbutton') ?? '' %}

            {% set btnColor = section.settings.buttoncolor ??
            attribute(section.settings,'buttoncolor') ??
            section.settings.get('buttoncolor') ??
            component.buttoncolor ??
            attribute(component,'buttoncolor') ??
            component.get('buttoncolor') ?? '' %}

            {% set buttonUrl = buttonUrl|default('')|trim %}
            {% set buttonText = buttonText|default('')|trim %}
            {% set btnBg = btnBg|default('#004956')|trim %}
            {% set btnColor = btnColor|default('#ffffff')|trim %}

            {% if buttonUrl and buttonText %}
            <a href="{{ buttonUrl }}" class="counter-btn"
                style="background:{{ btnBg }};border-radius:8px;border:1px solid rgba(255,255,255,0.15);color:{{ btnColor }};">
                {{ buttonText }}
            </a>
            {% endif %}
        </div>

        <div class="counter-right">
            {% if imgSrc %}
            <img class="counter-image" src="{{ imgSrc }}" alt="" loading="lazy" />
            {% endif %}
        </div>
    </div>
</section>