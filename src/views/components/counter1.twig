<section class="s-block s-block--counter" dir="rtl">

    {% set target = (section.settings.counterdate ?? component.counterdate ?? '')|default('')|trim %}
    {% set mainText = (section.settings.maintextcount ?? component.maintextcount ?? '')|default('')|trim %}
    {% set subText = (section.settings.subtextcount ?? component.subtextcount ?? '')|default('')|trim %}
    {% set imgSrc = (section.settings.imagecount ?? component.imagecount ?? '')|default('')|trim %}

    {% set itemBg = (section.settings['item-bac'] ?? attribute(component,'item-bac') ?? '#bdc5c7') %}
    {% set mainColor = (section.settings['main-txt-color'] ?? attribute(component,'main-txt-color') ?? '#000') %}
    {% set subColor = (section.settings['sub-txt-color'] ?? attribute(component,'sub-txt-color') ?? '#000') %}

    {% set buttonUrl = section.settings.buttonurl1 ?? attribute(component,'buttonurl1') ?? '' %}
    {% set buttonText = section.settings.buttonname ?? attribute(component,'buttonname') ?? '' %}
    {% set btnBg = section.settings.backbutton ?? attribute(component,'backbutton') ?? '#004956' %}
    {% set btnColor = section.settings.buttoncolor ?? attribute(component,'buttoncolor') ?? '#ffffff' %}

    {% set buttonUrl = buttonUrl|default('')|trim %}
    {% set buttonText = buttonText|default('')|trim %}

    <div class="counter-wrap s-card rounded-md" data-countdown="{{ target }}" style="background: {{ itemBg }};">

        <div class="counter-left">

            <div class="counter-cells">
                <div class="cell">
                    <div class="num js-days">00</div>
                    <div class="lbl">أيام</div>
                </div>
                <div class="cell">
                    <div class="num js-hours">00</div>
                    <div class="lbl">ساعات</div>
                </div>
                <div class="cell">
                    <div class="num js-mins">00</div>
                    <div class="lbl">دقائق</div>
                </div>
                <div class="cell">
                    <div class="num js-secs">00</div>
                    <div class="lbl">ثواني</div>
                </div>
            </div>

            {% if mainText %}
            <h3 class="counter-title" style="color: {{ mainColor }};">
                {{ mainText }}
            </h3>
            {% endif %}

            {% if subText %}
            <p class="counter-sub" style="color: {{ subColor }};">
                {{ subText }}
            </p>
            {% endif %}

            <div class="counter-msg" hidden></div>

            {% if buttonUrl and buttonText %}
            <a href="{{ buttonUrl }}" class="counter-btn" style="background:{{ btnBg }};color:{{ btnColor }};">
                {{ buttonText }}
            </a>
            {% endif %}

        </div>

        <div class="counter-right">
            {% if imgSrc %}
            <img class="counter-image" src="{{ imgSrc }}" alt="" loading="lazy" />
            {% endif %}
        </div>

    </div>

</section>
{% block stylecounter %}
<style>
    .s-block--counter {
    padding: 40px 0;
}

.s-block--counter .counter-wrap {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: row-reverse;
    overflow: hidden;
}

.s-block--counter .counter-right {
    width: 423px;
    flex: 0 0 423px;
}

.s-block--counter .counter-image {
    width: 100%;
    height: 100%;
    min-height: 483px;
    object-fit: cover;
    display: block;
}

.s-block--counter .counter-left {
    flex: 1;
    padding: 48px 56px;
    display: flex;
    gap: 24px;
    flex-direction: column;
    justify-content: center;
    text-align: center;
    align-items: flex-start;
}

.s-block--counter .counter-cells {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 36px;
}

.s-block--counter .cell {
    width: 112px;
    height: 132px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 15px;
    display: grid;
    place-items: center;
}

.counter-title {
    font-size: 36px;
    text-align: right;
}

.counter-sub {
    font-size: 16px;
    text-align: right;
}

/* 🔥 زرار مضبوط */
.counter-btn {
    width: fit-content;
    min-width: 160px;
    max-width: 100%;

    display: flex;
    align-items: center;
    justify-content: center;

    padding: 10px 18px;
    margin-top: 10px;

    border-radius: 8px;

    transition: 0.3s;
}

.counter-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
}

/* 📱 Mobile */
@media (max-width: 767px) {

    .s-block--counter .counter-wrap {
        flex-direction: column-reverse;
        padding: 16px;
    }

    .s-block--counter .counter-left {
        align-items: center;
        padding: 28px 16px;
    }

    .counter-title,
    .counter-sub {
        text-align: center;
    }

    .counter-btn {
        width: 100%;
        max-width: 260px;
        margin-inline: auto;
    }
}
</style>
{% endblock %} {% block scriptcounter %}
<script>
    (function () {
        function pad2(n) {
            return String(n).padStart(2, "0");
        }
        function normalizeDateString(s) {
            if (!s) return "";
            var str = String(s).trim();
            if (/^\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}(:\d{2})?$/.test(str)) {
                str = str.replace(/\s+/, "T");
            }
            return str;
        }
        function initCountdown(wrap) {
            var targetStr = normalizeDateString(wrap.getAttribute("data-countdown"));
            var msg = wrap.querySelector(".counter-msg");
            var dEl = wrap.querySelector(".js-days");
            var hEl = wrap.querySelector(".js-hours");
            var mEl = wrap.querySelector(".js-mins");
            var sEl = wrap.querySelector(".js-secs");
            function showMsg(t) {
                if (!msg) return;
                msg.hidden = !t;
                msg.textContent = t || "";
            }
            if (!targetStr) {
                showMsg("تنبيه: تاريخ ووقت العدّ التنازلي غير متوفر");
                return;
            }
            var target = new Date(targetStr);
            if (isNaN(target.getTime())) {
                showMsg("تنبيه: صيغة التاريخ غير صحيحة");
                return;
            }
            function tick() {
                var now = new Date();
                var diffMs = target.getTime() - now.getTime();
                if (diffMs <= 0) {
                    dEl.textContent = "00";
                    hEl.textContent = "00";
                    mEl.textContent = "00";
                    sEl.textContent = "00";
                    showMsg("انتهت المدة");
                    clearInterval(timer);
                    return;
                }
                var totalSeconds = Math.floor(diffMs / 1000);
                var days = Math.floor(totalSeconds / 86400);
                var rem = totalSeconds % 86400;
                var hours = Math.floor(rem / 3600);
                rem %= 3600;
                var mins = Math.floor(rem / 60);
                var secs = rem % 60;
                dEl.textContent = String(days);
                hEl.textContent = pad2(hours);
                mEl.textContent = pad2(mins);
                sEl.textContent = pad2(secs);
                showMsg("");
            }
            tick();
            var timer = setInterval(tick, 1000);
        }
        document.addEventListener("DOMContentLoaded", function () {
            document
                .querySelectorAll(".s-block--counter .counter-wrap[data-countdown]")
                .forEach(initCountdown);
        });
    })();
</script>
{% endblock %}


<h2 style="background:#d80b0b; padding:6px 12px; border-radius:6px; display:inline-block;">
    عرض خاص
</h2>
