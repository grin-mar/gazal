<section 
  class="s-block super-slider {{ section.settings['sec-width'] == 'Boxed' ? 'is-boxed' : 'is-full' }}" 
  dir="rtl"
>

{% set banners = section.settings.bannersitem.value ?? [] %}
{% set text_pos = section.settings['text-pos']|default('items-center justify-center text-center') %}

<div class="{{ section.settings['sec-width'] == 'Boxed' ? 'container' : '' }}">

<salla-slider 
  auto-play 
  interval="{{ section.settings.TIME|default(5000) }}"
  effect="{{ section.settings.move|default('slide')|lower }}"
  pagination
  type="fullwidth"
  class="super-slider__wrapper"
>

<div slot="items">

{% if banners|length %}

  {% for item in banners %}

  {% set img = item['bannersitem.banner-img-big'].url ?? '' %}
  {% set img_mobile = item['bannersitem.banner-small'].url ?? img %}

  <div class="swiper-slide super-slide">

    <!-- IMAGE -->
    {% if img %}
    <picture>
      <source media="(max-width:768px)" srcset="{{ img_mobile }}">
      <img 
        src="{{ img }}" 
        class="slide-img"
        loading="lazy"
        alt="banner"
      >
    </picture>
    {% endif %}

    <!-- CONTENT -->
    <div class="slide-overlay flex {{ text_pos }}">
      <div class="slide-content {{ section.settings.blur ? 'has-blur' : '' }}">

        {% if item['bannersitem.banner-main'] %}
          <h2 class="main-title">
            {{ item['bannersitem.banner-main'] }}
          </h2>
        {% endif %}

        {% if item['bannersitem.banner-des'] %}
          <p class="sub-text">
            {{ item['bannersitem.banner-des'] }}
          </p>
        {% endif %}

        {% if item['bannersitem.banner-button'] %}
          <a 
            href="#" 
            class="slide-btn"
          >
            {{ item['bannersitem.banner-button'] }}
          </a>
        {% endif %}

      </div>
    </div>

  </div>

  {% endfor %}

{% else %}
  <p style="text-align:center">لا يوجد بنرات</p>
{% endif %}

</div>
</salla-slider>

</div>
</section>


{% block styles %}
<style>

.super-slider {
  position: relative;
}

.super-slider.is-full {
  width: 100%;
}

.super-slider.is-boxed .container {
  border-radius: 12px;
  overflow: hidden;
}

/* IMAGE */
.slide-img {
  width: 100%;
  height: 500px;
  object-fit: cover;
}

/* CONTENT */
.slide-overlay {
  position: absolute;
  inset: 0;
  padding: 40px;
}

.slide-content {
  max-width: 500px;
}

/* BLUR */
.slide-content.has-blur {
  backdrop-filter: blur(5px);
  background: rgba(0,0,0,0.3);
  padding: 20px;
  border-radius: 10px;
}

/* TEXT */
.main-title {
  font-size: 28px;
  color: #fff;
}

.sub-text {
  font-size: 16px;
  color: #eee;
}

/* BUTTON */
.slide-btn {
  display: inline-block;
  margin-top: 10px;
  padding: 10px 20px;
  background: #000;
  color: #fff;
  border-radius: 6px;
  text-decoration: none;
}

/* MOBILE */
@media(max-width:768px){
  .slide-img {
    height: 350px;
  }
}

</style>
{% endblock %}