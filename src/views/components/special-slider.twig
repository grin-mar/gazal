{% set slider_id = 'special-slider-' ~ (position|default(0)) %}

{% set layout_type = attribute(component, 'sec-width')|default('full')|lower %}
{% set is_boxed = layout_type == 'boxed' %}

{% set auto_height = attribute(component, 'height') is same as(true) %}
{% set effect = attribute(component, 'move')|default('slide')|lower %}
{% set autoplay_speed = attribute(component, 'TIME')|default(5000) %}
{% set text_position = attribute(component, 'text-pos')|default('items-center justify-center text-center') %}
{% set pagination_shape = attribute(component, 'slide-pag')|default('cricle')|lower %}
{% set pagination_shape = pagination_shape == 'cricle' ? 'circle' : pagination_shape %}
{% set blur = attribute(component, 'blur') is same as(true) %}

{% set title_desktop = attribute(component, 'pc-main-1')|default(30) %}
{% set title_mobile = attribute(component, 'mob-main')|default(20) %}
{% set desc_desktop = attribute(component, 'pc-des')|default(18) %}
{% set desc_mobile = attribute(component, 'mob-des')|default(16) %}

{% set main_color = attribute(component, 'main-color')|default('#004956') %}
{% set special_color = attribute(component, 'special-word')|default('#ffffff') %}
{% set desc_color = attribute(component, 'des-color')|default('#004956') %}
{% set text_bg = attribute(component, 'background')|default('rgba(199,199,199,.45)') %}
{% set button_bg = attribute(component, 'burton-back')|default('#004956') %}
{% set button_color = attribute(component, 'button-color')|default('#ffffff') %}

{% set banners = attribute(component, 'banner-item')|default([]) %}

{% if banners|length %}
<section
    class="s-block s-block--special-slider {{ is_boxed ? '' : 's-block--full-bg' }} {{ is_repeated ? 'repeated-block' : '' }}"
    dir="rtl">
    <div class="{{ is_boxed ? 'container' : '' }}">
        <salla-slider id="{{ slider_id }}" type="{{ is_boxed ? 'carousel' : 'fullwidth' }}"
            class="home-slider special-slider special-slider--{{ pagination_shape }} {{ blur ? 'special-slider--blur' : 'special-slider--clear' }} {{ effect == 'zoom' ? 'special-slider--zoom' : '' }}"
            dir="rtl" pagination auto-play show-controls="false"
            effect="{{ effect in ['slide', 'fade', 'flip'] ? effect : 'slide' }}" speed="{{ autoplay_speed }}">
            <div slot="items">
                {% for banner in banners %}
                {% set title = attribute(banner, 'banner-item.collection.main-text')|default('') %}
                {% set subtitle = attribute(banner, 'banner-item.collection.des')|default('') %}
                {% set button_text = attribute(banner, 'banner-item.collection.ns_alzr')|default('') %}
                {% set button_url = attribute(banner, 'banner-item.collection.url-link')|default('#') %}
                {% set desktop_image = attribute(banner, 'banner-item.collection.pc-image')|default('') %}
                {% set mobile_image = attribute(banner, 'banner-item.collection.mob-ima')|default(desktop_image) %}
                {% set alt_text = title|trim ? title : 'special banner' %}

                {% set words = title|trim ? title|trim|split(' ') : [] %}
                {% set last_word = words|length ? words|last : '' %}
                {% set first_words = words|length > 1 ? words|slice(0, words|length - 1)|join(' ') : '' %}

                <div
                    class="swiper-slide relative special-slide {{ auto_height ? 'special-slide--auto' : 'special-slide--fixed' }}">
                    <picture>
                        {% if mobile_image %}
                        <source media="(max-width: 767px)" srcset="{{ mobile_image }}" />
                        {% endif %}
                        <img src="{{ desktop_image }}" alt="{{ alt_text }}" class="special-slide__img"
                            loading="{{ loop.first ? 'eager' : 'lazy' }}" draggable="false" />
                    </picture>

                    <div class="special-slider__content absolute inset-0 flex {{ text_position }}">
                        <div class="special-slide__text">
                            {% if title %}
                            <h3 class="special-slide__title"
                                style="color:{{ main_color }}; --title-desktop: {{ title_desktop }}px; --title-mobile: {{ title_mobile }}px;">
                                {% if first_words %}
                                <span>{{ first_words }}</span>
                                {% endif %}
                                {% if last_word %}
                                <span style="color:{{ special_color }};">{{ first_words ? ' ' : '' }}{{ last_word
                                    }}</span>
                                {% endif %}
                            </h3>
                            {% endif %}

                            {% if subtitle %}
                            <p class="special-slide__body"
                                style="color:{{ desc_color }}; --desc-desktop: {{ desc_desktop }}px; --desc-mobile: {{ desc_mobile }}px;">
                                {{ subtitle }}
                            </p>
                            {% endif %}

                            {% if button_text %}
                            <a href="{{ button_url ?: '#' }}"
                                class="special-slide__btn inline-flex items-center justify-center mt-6 px-6 py-3 no-underline"
                                style="background:{{ button_bg }}; color:{{ button_color }};">
                                {{ button_text }}
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </salla-slider>
    </div>
</section>
{% endif %}

{% block styleslider %}
<style>
    .s-block--special-slider {
        position: relative;
        overflow: hidden;
    }

    .s-block--special-slider .special-slider,
    .s-block--special-slider .special-slider .swiper,
    .s-block--special-slider .special-slider .swiper-wrapper {
        direction: rtl;
    }

    .s-block--special-slider .special-slide {
        position: relative;
        width: 100%;
        overflow: hidden;
    }

    .s-block--special-slider .special-slide--fixed {
        min-height: 420px;
    }

    @media (min-width: 1024px) {
        .s-block--special-slider .special-slide--fixed {
            min-height: 560px;
        }
    }

    .s-block--special-slider .special-slide__img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
    }

    .s-block--special-slider .special-slide--fixed .special-slide__img {
        object-fit: cover;
    }

    .s-block--special-slider .special-slide--auto .special-slide__img {
        position: relative;
        height: auto;
        object-fit: contain;
    }

    .s-block--special-slider .special-slider__content {
        width: 100%;
        padding-right: 24px;
        padding-left: 24px;
        box-sizing: border-box;
        z-index: 2;
    }

    @media (min-width: 768px) {
        .s-block--special-slider .special-slider__content {
            padding-right: 53px;
            padding-left: 53px;
        }
    }

    .s-block--special-slider .special-slide__text {
        max-width: 540px;
        display: flex;
        flex-direction: column;
        gap: 18px;
        justify-content: flex-start;
        align-items: flex-start;
        padding: 20px;
        border-radius: 20px;
    }

    .s-block--special-slider .special-slider--blur .special-slide__text {
        background: {
                {
                text_bg
            }
        }

        ;
        backdrop-filter: blur(.5rem);
        -webkit-backdrop-filter: blur(.5rem);
    }

    .s-block--special-slider .special-slider--clear .special-slide__text {
        background: transparent;
    }

    .s-block--special-slider .special-slide__title {
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -1px;
        margin: 0;
        font-size: var(--title-mobile);
        text-align: inherit;
    }

    @media (min-width: 768px) {
        .s-block--special-slider .special-slide__title {
            font-size: var(--title-desktop);
        }
    }

    .s-block--special-slider .special-slide__body {
        font-weight: 400;
        line-height: 1.8;
        margin: 0;
        font-size: var(--desc-mobile);
        text-align: inherit;
    }

    @media (min-width: 768px) {
        .s-block--special-slider .special-slide__body {
            font-size: var(--desc-desktop);
        }
    }

    .s-block--special-slider .special-slide__btn {
        min-width: 160px;
        min-height: 48px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 16px;
        line-height: 1;
        text-align: center;
    }

    .s-block--special-slider #{{ slider_id }
    }

    .swiper-pagination {
        position: absolute;
        right: 24px;
        left: auto;
        bottom: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 20;
    }

    @media (min-width: 768px) {
        .s-block--special-slider #{{ slider_id }
    }

    .swiper-pagination {
        right: 53px;
    }
    }

    .s-block--special-slider #{{ slider_id }
    }

    .swiper-pagination-bullet {
        opacity: 1;
        background: rgba(255, 255, 255, .55);
        transition: all .25s ease;
    }

    .s-block--special-slider #{{ slider_id }
    }

    .swiper-pagination-bullet-active {
        background: #fff;
    }

    .s-block--special-slider .special-slider--circle .swiper-pagination-bullet {
        width: 12px;
        height: 12px;
        border-radius: 999px;
    }

    .s-block--special-slider .special-slider--square .swiper-pagination-bullet {
        width: 12px;
        height: 12px;
        border-radius: 3px;
    }

    .s-block--special-slider .special-slider--line .swiper-pagination-bullet {
        width: 30px;
        height: 4px;
        border-radius: 999px;
    }

    .s-block--special-slider .swiper-button-next,
    .s-block--special-slider .swiper-button-prev {
        display: none !important;
    }

    .s-block--special-slider .special-slider--zoom .swiper-slide-active .special-slide__img {
        transform: scale(1.06);
        transition: transform 6s linear;
    }

    @media (max-width: 639px) {
        .s-block--special-slider .special-slider__content {
            padding-right: 16px;
            padding-left: 16px;
        }

        .s-block--special-slider .special-slide__text {
            max-width: 100%;
            padding: 16px;
            gap: 14px;
        }

        .s-block--special-slider .special-slide__btn {
            padding: 8px 14px;
            font-size: 14px;
            margin-top: 12px;
        }

        .s-block--special-slider #{{ slider_id }
    }

    .swiper-pagination {
        right: 16px;
        bottom: 12px;
        gap: 8px;
    }
    }
</style>
{% endblock %}

{% block scriptslider %}{% endblock %}