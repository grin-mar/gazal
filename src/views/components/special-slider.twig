<section class="s-block super-slider" dir="rtl">

<salla-slider auto-play pagination>

<div slot="items">

{% for item in items %}

<div class="swiper-slide">

  <!-- IMAGE -->
  {% if item.image.url %}
    <img src="{{ item.image.url }}" alt="banner">
  {% endif %}

  <!-- TEXT -->
  {% if item.title %}
    <h2>{{ item.title }}</h2>
  {% endif %}

  {% if item.description %}
    <p>{{ item.description }}</p>
  {% endif %}

  {% if item.url %}
    <a href="{{ item.url }}">تسوق الآن</a>
  {% endif %}

</div>

{% endfor %}

</div>
</salla-slider>

</section>