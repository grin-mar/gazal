<section class="s-block s-block--default {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider id="gaxal-main-slider" auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ component.TIME1 }}" pagination show-controls="false" dir="rtl">

      <div slot="items">

        {% for banner in component.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ?: img %}

        <div class="swiper-slide relative">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="w-full h-full object-cover">
          </picture>

          <div class="absolute inset-0 flex {{ component.text_pos }} px-6 md:px-12">

            <div class="premium-content {{ component.blur2 ? 'has-blur' : '' }}"
              style="{{ component.blur2 ? 'background:' ~ component.background22 : '' }}">

              {% if banner.banner_main %}
              <h2 class="premium-title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">

                {% set words = banner.banner_main|split(' ') %}
                {% set last = words|last %}
                {% set rest = words|slice(0, words|length - 1)|join(' ') %}

                {{ rest }}
                <span style="color:{{ component.special_word }};">{{ last }}</span>

              </h2>
              {% endif %}

              {% if banner.banne_des %}
              <p class="premium-desc" style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a href="
{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest
{% elseif banner.banner_url_but == 'offers' %}/sale
{% elseif banner.banner_url_but == 'brands' %}/brands
{% else %}#{% endif %}" class="premium-btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>
          </div>

        </div>

        {% endfor %}

      </div>
    </salla-slider>

  </div>
</section>


{% block styleslider %}
<style>
  
#gaxal-main-slider .swiper-slide {
  position: relative;
  overflow: hidden;
}

{% if component.height1 %}
#gaxal-main-slider .swiper-slide {
  height: auto;
}
{% else %}
#gaxal-main-slider .swiper-slide {
  min-height: 650px;
}
{% endif %}

@media (max-width: 768px) {
  {% if component.height1 %}
  #gaxal-main-slider .swiper-slide {
    height: auto;
  }
  {% else %}
  #gaxal-main-slider .swiper-slide {
    min-height: 340px;
  }
  {% endif %}
}

#gaxal-main-slider img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 6s ease;
}

#gaxal-main-slider .swiper-slide-active img {
  transform: scale(1.05);
}

.premium-content {
  display: flex;
  flex-direction: column;
  gap: 18px;
  max-width: 520px;
  padding: 28px;
  border-radius: 14px;
}

.premium-content.has-blur {
  backdrop-filter: blur(8px);
}

.premium-title {
  font-weight: 800;
  line-height: 1.25;
  letter-spacing: -0.5px;
}

.premium-desc {
  line-height: 1.7;
  opacity: 0.9;
}

.premium-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  height: 48px;
  padding: 0 28px;

  border-radius: 999px;
  font-weight: 600;

  transition: all 0.3s ease;
}

.premium-btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

#gaxal-main-slider .swiper-pagination {
  position: absolute;
  bottom: 20px;
  right: 20px;
  display: flex;
  gap: 8px;
}

#gaxal-main-slider .swiper-pagination-bullet {
  background: #fff;
  opacity: 0.5;
  transition: all 0.3s ease;
}

#gaxal-main-slider .swiper-pagination-bullet-active {
  opacity: 1;
  transform: scale(1.2);
}

{% if component.slide_pag == 'square' %}
#gaxal-main-slider .swiper-pagination-bullet {
  width: 12px;
  height: 12px;
  border-radius: 4px;
}
{% elseif component.slide_pag == 'line' %}
#gaxal-main-slider .swiper-pagination-bullet {
  width: 32px;
  height: 4px;
  border-radius: 4px;
}
{% else %}
#gaxal-main-slider .swiper-pagination-bullet {
  width: 12px;
  height: 12px;
  border-radius: 999px;
}
{% endif %}

</style>

{% endblock %}

{% block scriptslider%}
<script>
  document.addEventListener("DOMContentLoaded", function () {

      const sliderEl = document.querySelector("#gaxal-main-slider");
      if (!sliderEl) return;

      const init = () => {
        if (!sliderEl.swiper) return;

        const swiper = sliderEl.swiper;

        const effect = "{{ component.move1|lower }}";

        if (effect === "fade") {
          swiper.params.effect = "fade";
        } else if (effect === "flip") {
          swiper.params.effect = "flip";
        } else if (effect === "zoom") {
          swiper.params.effect = "fade";
        } else {
          swiper.params.effect = "slide";
        }

        if ({{ component.TIME1 |default (0) }
      } > 0) {
      swiper.params.autoplay = {
        delay: {{ component.TIME1 }
    },
    disableOnInteraction: false,
      };
    }

    swiper.update();
  };

    setTimeout(init, 300);

});
</script>
  {% endblock %}
  
  <h2 style="color: rgb(122, 0, 20);">ssssss</h2>