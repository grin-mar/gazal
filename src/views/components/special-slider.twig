<section class="s-block home-slider {{ component.sec_width == 'full' ? 'full' : 'boxed' }}" dir="rtl">

  <salla-slider id="home-slider" auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
    interval="{{ component.TIME1 }}" pagination show-controls="false" dir="rtl">

    <div slot="items">

      {% for banner in component.banner_item %}

      {% set img = banner.banner_mg_big %}
      {% set mob = banner.banne_small ?: img %}

      <div class="swiper-slide home-slide">

        <picture>
          <source media="(max-width:768px)" srcset="{{ mob }}">
          <img src="{{ img }}" class="home-img" loading="lazy">
        </picture>

        <div class="home-overlay {{ component.text_pos }}">

          <div class="home-content {{ component.blur2 ? 'blur' : '' }}">

            {% if banner.banner_main %}
            <h2 class="home-title">

              {% set words = banner.banner_main|split(' ') %}
              {% set last = words|last %}
              {% set rest = words|slice(0, words|length - 1)|join(' ') %}

              {{ rest }}
              <span class="last-word">{{ last }}</span>

            </h2>
            {% endif %}

            {% if banner.banne_des %}
            <p class="home-desc">{{ banner.banne_des }}</p>
            {% endif %}

            {% if banner.banner_button %}
            <a href="
{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest
{% elseif banner.banner_url_but == 'offers' %}/sale
{% elseif banner.banner_url_but == 'brands' %}/brands
{% else %}#{% endif %}
" class="home-btn">

              {{ banner.banner_button }}

            </a>
            {% endif %}

          </div>
        </div>

      </div>

      {% endfor %}

    </div>
  </salla-slider>

</section>


