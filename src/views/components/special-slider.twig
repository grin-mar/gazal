<section class="s-block s-block--default home-slider {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="home-main-slider"
      pagination
      type="carousel"
      dir="rtl"
      show-controls="true">

      <div slot="items">

        {% for banner in component.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex {{ component.text_pos }}">

            <div class="home-slide__text {{ component.blur2 ? 'has-blur' : '' }}"
              {% if component.blur2 %}
              style="background: rgba(0,0,0,0.35);"
              {% endif %}>

              {% if banner.banner_main %}
              <h3 class="home-slide__title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">
                {% set words = banner.banner_main|split(' ') %}
                {% set last = words|last %}
                {% set rest = words|slice(0, words|length - 1)|join(' ') %}
                {{ rest }}
                <span style="color:{{ component.special_word }};">{{ last }}</span>
              </h3>
              {% endif %}

              {% if banner.banne_des %}
              <p class="home-slide__body"
                style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a
                href="{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest{% elseif banner.banner_url_but == 'offers' %}/sale{% elseif banner.banner_url_but == 'brands' %}/brands{% else %}#{% endif %}"
                class="home-slide__btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>

        {% endfor %}

      </div>

    </salla-slider>

  </div>
</section>

{% block styleslider %}
<style>
.home-slider {
  position: relative;
  overflow: hidden;
}

.home-slide {
  position: relative;
  min-height: 650px;
}

.home-slide__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* content */
.home-slider__content {
  position: absolute;
  inset: 0;
  display: flex;
  padding: 0 40px;
  pointer-events: none;
}

.home-slide__text {
  max-width: 520px;
  margin: 30px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  pointer-events: auto;
}

/* blur */
.home-slide__text.has-blur {
  backdrop-filter: blur(10px);
  padding: 20px;
  border-radius: 14px;
}

/* animation keyframes */
@keyframes fade-in-right {
  0% {
    transform: translateX(50px);
    opacity: 0;
  }
  100% {
    transform: translateX(0);
    opacity: 1;
  }
}

/* reset */
.home-slide__title,
.home-slide__body,
.home-slide__btn {
  opacity: 0;
}

/* animation active */
.swiper-slide-active .home-slide__title {
  animation: fade-in-right 0.7s ease forwards;
}

.swiper-slide-active .home-slide__body {
  animation: fade-in-right 0.7s ease 0.2s forwards;
}

.swiper-slide-active .home-slide__btn {
  animation: fade-in-right 0.7s ease 0.4s forwards;
}

/* arrows */
.home-slider .swiper-button-next,
.home-slider .swiper-button-prev {
  color: #fff;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(0,0,0,0.3);
}

/* pagination */
.home-slider .swiper-pagination {
  position: absolute;
  right: 20px;
  bottom: 20px;
}
</style>
{% endblock %}



{% block scriptslider %}
<script>
document.addEventListener("DOMContentLoaded", function () {

  const el = document.querySelector('#home-main-slider');
  if (!el) return;

  function init(){
    if (!el.swiper){
      setTimeout(init, 200);
      return;
    }

    const swiper = el.swiper;

    /* 🎬 effect */
    let raw = "{{ component.move1|lower }}";
    let effect = 'slide';

    if (raw.includes('fade')) effect = 'fade';
    else if (raw.includes('flip')) effect = 'flip';
    else if (raw.includes('zoom')) effect = 'fade'; // fallback
    else effect = 'slide';

    swiper.params.effect = effect;

    if(effect === 'fade'){
      swiper.params.fadeEffect = { crossFade: true };
    }

    /* ⏱️ speed */
    let delay = Number({{ component.TIME1|default(0) }});
    if(delay > 0 && delay < 100) delay *= 1000;

    if(delay > 0){
      swiper.params.autoplay = {
        delay: delay,
        disableOnInteraction: false
      };
      swiper.autoplay.start();
    }

    swiper.params.speed = 700;
    swiper.update();
  }

  init();
});
</script>
