<section class="s-block s-block--default gaxal-slider {{ component.sec_width == 'full' ? 'is-full' : 'is-boxed' }}"
  dir="rtl">

  <salla-slider id="gaxal-main-slider" auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
    interval="{{ component.TIME1 }}" pagination show-controls="false" dir="rtl">

    <div slot="items">

      {% for banner in component.banner_item %}

      {% set img = banner.banner_mg_big %}
      {% set mob = banner.banne_small ?: img %}

      <div class="swiper-slide gaxal-slide">

        <picture>
          <source media="(max-width:768px)" srcset="{{ mob }}">
          <img src="{{ img }}" class="gaxal-img" loading="lazy">
        </picture>

        <div class="gaxal-overlay {{ component.text_pos }}">

          <div class="gaxal-content {{ component.blur2 ? 'has-blur' : '' }}">

            {% if banner.banner_main %}
            <h2 class="gaxal-title">

              {% set words = banner.banner_main|split(' ') %}
              {% set last = words|last %}
              {% set rest = words|slice(0, words|length - 1)|join(' ') %}

              {{ rest }}
              <span class="last-word">{{ last }}</span>

            </h2>
            {% endif %}

            {% if banner.banne_des %}
            <p class="gaxal-desc">{{ banner.banne_des }}</p>
            {% endif %}

            {% if banner.banner_button %}
            <a href="
{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest
{% elseif banner.banner_url_but == 'offers' %}/sale
{% elseif banner.banner_url_but == 'brands' %}/brands
{% else %}#{% endif %}
" class="gaxal-btn">
              {{ banner.banner_button }}
            </a>
            {% endif %}

          </div>
        </div>

      </div>

      {% endfor %}

    </div>
  </salla-slider>

</section>

  <h2 style="color: rgb(193, 20, 179);">ddddddww</h2>


  <pre>{{ section.settings.banner_item|json_encode }}</pre>