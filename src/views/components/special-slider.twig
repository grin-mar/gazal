<section class="s-block s-block--default home-slider {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="home-main-slider"
      auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ component.TIME1 > 0 and component.TIME1 < 100 ? component.TIME1 * 1000 : component.TIME1 }}"
      pagination
      type="carousel"
      dir="rtl"
      show-controls="true">

      <div slot="items">

        {% for banner in component.banner_item %}
        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex {{ component.text_pos }}">

            <div class="home-slide__text {{ component.blur2 ? 'has-blur' : '' }}"
              {% if component.blur2 %}
              style="background: rgba(0,0,0,0.35);"
              {% endif %}>

              {% if banner.banner_main %}
              <h3 class="home-slide__title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">
                {{ banner.banner_main }}
              </h3>
              {% endif %}

              {% if banner.banne_des %}
              <p class="home-slide__body"
                style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a href="#"
                class="home-slide__btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>
        {% endfor %}

      </div>
    </salla-slider>

  </div>
</section>

{% block styleslider %}
<style>




.home-slider {
  position: relative;
  overflow: hidden;
}

.home-slide {
  position: relative;
  min-height: 650px;
}

.home-slide__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* content */
.home-slider__content {
  position: absolute;
  inset: 0;
  display: flex;
  padding: 0 40px;
  pointer-events: none;
}

/* 💣 بوكس مرن */
.home-slide__text {
  max-width: 90%;
  width: fit-content;
  min-width: 280px;
  margin: 30px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  pointer-events: auto;
}

/* blur */
.has-blur {
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 20px;
  border-radius: 14px;
}

/* text fix */
.home-slide__title {
  line-height: 1.4;
  word-break: break-word;
}

.home-slide__body {
  line-height: 1.6;
  word-break: break-word;
}

/* arrows */
.home-slider .swiper-button-next,
.home-slider .swiper-button-prev {
  color: #fff;
  background: rgba(0,0,0,0.3);
  width: 40px;
  height: 40px;
  border-radius: 50%;
}

/* responsive */
@media (max-width:768px){
  .home-slide {
    min-height: 320px;
  }

  .home-slider__content {
    padding: 0 16px;
  }

  .home-slide__text {
    margin: 12px;
  }
}



</style>
{% endblock %}


{% block scriptslider %}
<script>
document.addEventListener("DOMContentLoaded", function () {

  const el = document.querySelector('#home-main-slider');
  if (!el) return;

  function init(){
    if (!el.swiper){
      setTimeout(init, 200);
      return;
    }

    const swiper = el.swiper;

    /* 🎬 الحركة من العميل */
    let raw = "{{ component.move1|lower }}";
    let effect = 'slide';

    if (raw.includes('fade')) effect = 'fade';
    else if (raw.includes('flip')) effect = 'flip';
    else if (raw.includes('cube')) effect = 'cube';
    else if (raw.includes('cover')) effect = 'coverflow';

    swiper.params.effect = effect;

    if(effect === 'fade'){
      swiper.params.fadeEffect = { crossFade: true };
    }

    /* ⏱️ الوقت */
    let delay = Number({{ component.TIME1|default(0) }});

    if(delay > 0 && delay < 100){
      delay *= 1000;
    }

    if(delay > 0){
      swiper.params.autoplay = {
        delay: delay,
        disableOnInteraction: false
      };

      if(swiper.autoplay) swiper.autoplay.start();
    }

    swiper.params.speed = 700;
    swiper.params.allowTouchMove = true;

    swiper.update();
  }

  init();
});
</script>
{% endblock %}