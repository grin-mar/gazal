<section class="s-block s-block--default home-slider {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="home-main-slider"
      auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ component.TIME1 * 1000 }}"
      pagination
      type="carousel"
      dir="rtl"
      show-controls="true">

      <div slot="items">

        {% for banner in component.banner_item %}
        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex {{ component.text_pos }}">

            <div class="home-slide__text {{ component.blur2 ? 'has-blur' : '' }}"
              {% if component.blur2 %}
              style="background: rgba(0,0,0,0.3);"
              {% endif %}>

              <h3 class="home-slide__title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">
                {{ banner.banner_main }}
              </h3>

              <p class="home-slide__body"
                style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>

              {% if banner.banner_button %}
              <a href="#"
                class="home-slide__btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>
        {% endfor %}

      </div>
    </salla-slider>

  </div>
</section>

{% block styleslider %}
<style>
.home-slide {
  position: relative;
  min-height: 650px;
}

.home-slide__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* content */
.home-slider__content {
  position: absolute;
  inset: 0;
  display: flex;
  padding: 0 40px;
  pointer-events: none;
}

.home-slide__text {
  max-width: 520px;
  margin: 30px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  pointer-events: auto;
}

/* blur */
.has-blur {
  backdrop-filter: blur(8px);
  padding: 20px;
  border-radius: 12px;
}

/* 🔥 fade animation */
@keyframes fadeMove {
  from {
    transform: translateX(40px);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* reset */
.home-slide__title,
.home-slide__body,
.home-slide__btn {
  opacity: 0;
}

/* apply animation */
.swiper-slide-active .home-slide__title {
  animation: fadeMove 0.6s ease forwards;
}

.swiper-slide-active .home-slide__body {
  animation: fadeMove 0.6s ease 0.2s forwards;
}

.swiper-slide-active .home-slide__btn {
  animation: fadeMove 0.6s ease 0.4s forwards;
}

/* arrows */
.swiper-button-next,
.swiper-button-prev {
  color: #fff;

}
</style>
{% endblock %}



{% block scriptslider %}
<script>
document.addEventListener("DOMContentLoaded", function () {
  const el = document.querySelector('#home-main-slider');
  if (!el) return;

  function init(){
    if (!el.swiper){
      setTimeout(init, 200);
      return;
    }

    const swiper = el.swiper;

    let effect = "{{ component.move1|lower }}";

    if(effect === 'fade'){
      swiper.params.effect = 'fade';
      swiper.params.fadeEffect = { crossFade: true };
    }

    swiper.update();
  }

  init();
});
</script>
{% endblock %}