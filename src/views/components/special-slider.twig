<section class="s-block s-block--default {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider id="gaxal-main-slider" auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ component.TIME1 }}" pagination show-controls="false" dir="rtl">

      <div slot="items">

        {% for banner in component.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ?: img %}

        <div class="swiper-slide relative">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="w-full h-full object-cover">
          </picture>

          <div class="absolute inset-0 flex {{ component.text_pos }} p-6">

            <div class="flex flex-col gap-4 max-w-md
{{ component.blur2 ? 'backdrop-blur-sm p-4 rounded-lg' : '' }}"
              style="{{ component.blur2 ? 'background:' ~ component.background22 : '' }}">

              {% if banner.banner_main %}
              <h2 class="font-bold" style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">

                {% set words = banner.banner_main|split(' ') %}
                {% set last = words|last %}
                {% set rest = words|slice(0, words|length - 1)|join(' ') %}

                {{ rest }}
                <span style="color:{{ component.special_word }};">{{ last }}</span>

              </h2>
              {% endif %}

              {% if banner.banne_des %}
              <p style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a href="
{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest
{% elseif banner.banner_url_but == 'offers' %}/sale
{% elseif banner.banner_url_but == 'brands' %}/brands
{% else %}#{% endif %}
" class="btn" style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>
          </div>

        </div>

        {% endfor %}

      </div>
    </salla-slider>

  </div>
</section>
  <salla-slider id="gaxal-main-slider" auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
    interval="{{ component.TIME1 }}" pagination show-controls="false" dir="rtl">

    <div slot="items">

      {% for banner in component.banner_item %}

      {% set img = banner.banner_mg_big %}
      {% set mob = banner.banne_small ?: img %}

      <div class="swiper-slide gaxal-slide">

        <picture>
          <source media="(max-width:768px)" srcset="{{ mob }}">
          <img src="{{ img }}" class="gaxal-img" loading="lazy">
        </picture>

        <div class="gaxal-overlay flex {{ component.text_pos }}">

          <div class="gaxal-content {{ component.blur2 ? 'has-blur' : '' }}">

            {% if banner.banner_main %}
            <h2 class="gaxal-title">

              {% set words = banner.banner_main|split(' ') %}
              {% set last = words|last %}
              {% set rest = words|slice(0, words|length - 1)|join(' ') %}

              {{ rest }}
              <span class="last-word">{{ last }}</span>

            </h2>
            {% endif %}

            {% if banner.banne_des %}
            <p class="gaxal-desc">{{ banner.banne_des }}</p>
            {% endif %}

            {% if banner.banner_button %}
            <a href="
{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest
{% elseif banner.banner_url_but == 'offers' %}/sale
{% elseif banner.banner_url_but == 'brands' %}/brands
{% else %}#{% endif %}
" class="gaxal-btn">
              {{ banner.banner_button }}
            </a>
            {% endif %}

          </div>
        </div>

      </div>

      {% endfor %}

    </div>
  </salla-slider>

</section>
{% block styleslider %}
<style>
.gaxal-slider.is-full{
    width:100%;
}

.gaxal-slider.is-boxed{
    max-width:1200px;
    margin:auto;
    border-radius:16px;
    overflow:hidden;
}

.gaxal-slide{
    position:relative;
}

.gaxal-img{
    width:100%;
    height:100%;
    object-fit:cover;
    position:absolute;
    inset:0;
}

.gaxal-overlay{
    position:absolute;
    inset:0;
    display:flex;
    padding:40px;
}

.gaxal-content{
    max-width:500px;
    display:flex;
    flex-direction:column;
    gap:16px;
}

.gaxal-content.has-blur{
    backdrop-filter:blur(5px);
    background:var(--overlay-bg);
    padding:20px;
    border-radius:12px;
}

.gaxal-title{
    font-size:var(--title-size);
    color:var(--title-color);
    font-weight:700;
}

.gaxal-desc{
    font-size:var(--desc-size);
    color:var(--desc-color);
}

.gaxal-btn{
    display:flex;
    align-items:center;
    justify-content:center;

    width:220px;
    height:48px;

    background:var(--btn-bg);
    color:var(--btn-color);
    border-radius:10px;
    font-weight:600;
}

#gaxalSlider .swiper-pagination{
    right:30px;
    bottom:20px;
}

#gaxalSlider .swiper-pagination-bullet{
    background:#fff;
    opacity:0.6;
}

#gaxalSlider .swiper-pagination-bullet-active{
    opacity:1;
}

@media(max-width:768px){

.gaxal-overlay{
    padding:16px;
}

.gaxal-title{
    font-size:var(--title-size-mobile);
}

.gaxal-desc{
    font-size:var(--desc-size-mobile);
}

.gaxal-btn{
    width:100%;
    max-width:200px;
}

}
</style>
{% endblock %}

{% block scriptslider%}
<script>
  document.addEventListener("DOMContentLoaded", function () {

      const slider = document.querySelector("#gaxalSlider");
      if (!slider) return;

      const swiper = slider.swiper;
      if (!swiper) return;

      /* effect */
      const effect = slider.getAttribute("data-effect");

      if (effect === "fade") {
        swiper.params.effect = "fade";
      }
      else if (effect === "flip") {
        swiper.params.effect = "flip";
      }
      else if (effect === "zoom") {
        swiper.params.effect = "fade";
      }
      else {
        swiper.params.effect = "slide";
      }

      swiper.update();

    });
  </script>
