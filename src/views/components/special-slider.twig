<section class="s-block s-block--default home-slider {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}" dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider
      id="home-main-slider"
      pagination
      type="carousel"
      dir="rtl"
      show-controls="false">

      <div slot="items">

        {% for banner in component.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex {{ component.text_pos }}">

            <div class="home-slide__text {{ component.blur2 ? 'has-blur' : '' }}"
              {% if component.blur2 %}
              style="background: rgba(0,0,0,0.35);"
              {% endif %}>

              {% if banner.banner_main %}
              <h3 class="home-slide__title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">

                {% set words = banner.banner_main|split(' ') %}
                {% set last = words|last %}
                {% set rest = words|slice(0, words|length - 1)|join(' ') %}

                {{ rest }}
                <span style="color:{{ component.special_word }};">{{ last }}</span>
              </h3>
              {% endif %}

              {% if banner.banne_des %}
              <p class="home-slide__body"
                style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a
                href="{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest{% elseif banner.banner_url_but == 'offers' %}/sale{% elseif banner.banner_url_but == 'brands' %}/brands{% else %}#{% endif %}"
                class="home-slide__btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>

        {% endfor %}

      </div>

    </salla-slider>

  </div>
</section>


{% block styleslider %}
<style>

.home-slider {
  position: relative;
  overflow: hidden;
}

.home-slide {
  position: relative;
  min-height: 650px;
}

.home-slide__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.home-slider__content {
  position: absolute;
  inset: 0;
  display: flex;
  padding: 0 40px;
  z-index: 2;
}

.home-slide__text {
  max-width: 520px;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16px;
  word-break: break-word;
  overflow-wrap: break-word;
}

.home-slide__text.has-blur {
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  padding: 20px;
  border-radius: 14px;
}

.home-slide__title {
  font-weight: 700;
  line-height: 1.3;
}

.home-slide__body {
  line-height: 1.6;
}

.home-slide__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 26px;
  border-radius: 10px;
  margin-top: 10px;
  font-weight: 600;
  transition: 0.3s;
}

.home-slide__btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

/* pagination */

.home-slider #home-main-slider .swiper-pagination {
  position: absolute;
  right: 20px;
  bottom: 20px;
  display: flex;
  gap: 8px;
}

.home-slider #home-main-slider .swiper-pagination-bullet {
  background: #fff;
  opacity: 0.6;
  transition: all .2s ease;
}

.home-slider #home-main-slider .swiper-pagination-bullet-active {
  opacity: 1;
}

/* shape control */

{% set shape = component.shkl_aalamat_altnql|default('circle') %}

{% if shape == 'square' %}
.home-slider #home-main-slider .swiper-pagination-bullet {
  width: 12px;
  height: 12px;
  border-radius: 4px;
}
{% elseif shape == 'line' %}
.home-slider #home-main-slider .swiper-pagination-bullet {
  width: 32px;
  height: 4px;
  border-radius: 4px;
}
{% else %}
.home-slider #home-main-slider .swiper-pagination-bullet {
  width: 12px;
  height: 12px;
  border-radius: 999px;
}
{% endif %}

@media (max-width:768px){

.home-slide {
  min-height: 320px;
}

.home-slider__content {
  padding: 0 16px;
}

.home-slide__title {
  font-size: {{ component.mob_main }}px;
}

.home-slide__body {
  font-size: {{ component.mob_des }}px;
}

.home-slide__btn {
  padding: 8px 14px;
  font-size: 14px;
}

}

</style>
{% endblock %}


{% block scriptslider %}
<script>
document.addEventListener("DOMContentLoaded", function () {

  const sliderEl = document.querySelector('#home-main-slider');
  if (!sliderEl) return;

  function init() {
    if (!sliderEl.swiper) {
      setTimeout(init, 200);
      return;
    }

    const swiper = sliderEl.swiper;

    /* effect */
    let effect = "{{ component.move1|default('slide')|lower }}";
    if (effect === 'zoom') effect = 'fade';

    swiper.params.effect = effect;

    /* autoplay speed */
    const delay = Number({{ component.TIME1|default(0) }});

    if (delay > 0) {
      swiper.params.autoplay = {
        delay: delay,
        disableOnInteraction: false
      };

      if (swiper.autoplay && swiper.autoplay.start) {
        swiper.autoplay.start();
      }
    } else {
      swiper.params.autoplay = false;

      if (swiper.autoplay && swiper.autoplay.stop) {
        swiper.autoplay.stop();
      }
    }

    swiper.update();
  }

  init();

});
</script>
{% endblock %} 

