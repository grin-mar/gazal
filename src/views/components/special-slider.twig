<section class="s-block home-slider {{ section.settings.sec_width == 'full' ? 'full' : 'boxed' }}" dir="rtl">

  <salla-slider id="home-slider" auto-play="{{ section.settings.TIME1 > 0 ? 'true' : 'false' }}"
    interval="{{ section.settings.TIME1 }}" pagination show-controls="false" dir="rtl">

    <div slot="items">

      {% for banner in section.settings.banner_item %}

      {% set img = banner.banner_mg_big %}
      {% set mob = banner.banne_small ?: img %}

      <div class="swiper-slide home-slide">

        <picture>
          <source media="(max-width:768px)" srcset="{{ mob }}">
          <img src="{{ img }}" class="home-img" loading="lazy">
        </picture>

        <div class="home-overlay {{ section.settings.text_pos }}">

          <div class="home-content {{ section.settings.blur2 ? 'blur' : '' }}">

            {% if banner.banner_main %}
            <h2 class="home-title">{{ banner.banner_main }}</h2>
            {% endif %}

            {% if banner.banne_des %}
            <p class="home-desc">{{ banner.banne_des }}</p>
            {% endif %}

            {% if banner.banner_button %}
            <a href="{{ banner.banner_url_but ?: '#' }}" class="home-btn">
              {{ banner.banner_button }}
            </a>
            {% endif %}

          </div>
        </div>

      </div>

      {% endfor %}

    </div>
  </salla-slider>

</section>
  <h2 style="color: rgb(21, 0, 4);">يييي</h2>