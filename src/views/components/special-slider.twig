<section class="s-block s-block--default home-slider {{ component.sec_width == 'full' ? 's-block--full-bg' : '' }}"
  dir="rtl">

  <div class="{{ component.sec_width == 'Boxed' ? 'container' : '' }}">

    <salla-slider id="home-main-slider" auto-play="{{ component.TIME1 > 0 ? 'true' : 'false' }}"
      interval="{{ component.TIME1 }}" pagination type="carousel" dir="rtl" show-controls="false">

      <div slot="items">

        {% for banner in component.banner_item %}

        {% set img = banner.banner_mg_big %}
        {% set mob = banner.banne_small ? banner.banne_small : img %}

        <div class="swiper-slide home-slide">

          <picture>
            <source media="(max-width:768px)" srcset="{{ mob }}">
            <img src="{{ img }}" class="home-slide__img">
          </picture>

          <div class="home-slider__content flex items-center">

            <div class="home-slide__text {{ component.blur2 ? 'has-blur' : '' }}" {% if component.blur2 %}
              style="background:{{ component.background22 }};" {% endif %}>

              {% if banner.banner_main %}
              <h3 class="home-slide__title"
                style="color:{{ component.main_color }}; font-size:{{ component.pc_main_1 }}px;">
                {% set words = banner.banner_main|split(' ') %}
                {% set last = words|last %}
                {% set rest = words|slice(0, words|length - 1)|join(' ') %}

                {{ rest }}
                <span style="color:{{ component.special_word }};">{{ last }}</span>
              </h3>
              {% endif %}

              {% if banner.banne_des %}
              <p class="home-slide__body" style="color:{{ component.des_color }}; font-size:{{ component.pc_des }}px;">
                {{ banner.banne_des }}
              </p>
              {% endif %}

              {% if banner.banner_button %}
              <a href="{% if banner.banner_url_but == 'latest-products' %}/products?sort=latest{% elseif banner.banner_url_but == 'offers' %}/sale{% elseif banner.banner_url_but == 'brands' %}/brands{% else %}#{% endif %}"
                class="home-slide__btn"
                style="background:{{ component.burton_back }}; color:{{ component.button_color }};">
                {{ banner.banner_button }}
              </a>
              {% endif %}

            </div>

          </div>

        </div>

        {% endfor %}

      </div>

    </salla-slider>

  </div>
</section>


{% block styleslider %}
<style>

.home-slider {
  position: relative;
  overflow: hidden;
}

.home-slide {
  position: relative;
  min-height: 650px;
}

.home-slide__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.home-slider__content {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  padding: 0 40px;
  z-index: 2;
}

.home-slide__text {
  max-width: 500px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.home-slide__text.has-blur {
  backdrop-filter: blur(6px);
  padding: 20px;
  border-radius: 12px;
  background: rgba(0,0,0,0.3);
}

.home-slide__title {
  font-weight: 600;
  line-height: 1.2;
}

.home-slide__body {
  line-height: 1.6;
}

.home-slide__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 26px;
  border-radius: 10px;
  text-decoration: none;
  margin-top: 10px;
  font-weight: 600;
  transition: 0.3s;
}

.home-slide__btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

.home-slider #home-main-slider .swiper-pagination {
  position: absolute;
  right: 20px;
  bottom: 20px;
  display: flex;
  gap: 8px;
}

.home-slider #home-main-slider .swiper-pagination-bullet {
  background: #fff;
  opacity: 0.6;
}

.home-slider #home-main-slider .swiper-pagination-bullet-active {
  opacity: 1;
}

@media (max-width: 768px) {

.home-slide {
  min-height: 320px;
}

.home-slider__content {
  padding: 0 16px;
}

.home-slide__btn {
  padding: 8px 14px;
  font-size: 14px;
}

}
</style>
{% endblock %}

{% block scriptslider %}
{% endblock %}