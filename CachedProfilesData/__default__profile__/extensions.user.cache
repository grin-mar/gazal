ternal Browser)","category":"Live Preview"},{"command":"livePreview.setDefaultOpenFile","title":"Open Automatically on Server Start","category":"Live Preview"},{"command":"livePreview.runServerLoggingTask","title":"Start Server Logging","category":"Live Preview"},{"command":"livePreview.end","title":"Stop Server","category":"Live Preview"},{"command":"livePreview.start.preview.atFileString","title":"Start Server at File Path String","category":"Live Preview"}],"menus":{"editor/title":[{"command":"livePreview.start.preview.atFile","when":"editorLangId == html && !notebookEditorFocused","group":"navigation"}],"explorer/context":[{"command":"livePreview.start.preview.atFile","when":"resourceLangId == html","group":"1_livepreview@1"},{"command":"livePreview.setDefaultOpenFile","when":"resourceLangId == html","group":"1_livepreview@2"}],"editor/context":[{"command":"livePreview.start.preview.atFile","when":"resourceLangId == html","group":"1_livepreview@1"},{"command":"livePreview.setDefaultOpenFile","when":"resourceLangId == html","group":"1_livepreview@2"}],"commandPalette":[{"command":"livePreview.start","when":"!LivePreviewServerOn"},{"command":"livePreview.start.preview.atFile","when":"false"},{"command":"livePreview.start.preview.atFileString","when":"false"},{"command":"livePreview.start.debugPreview.atFile","when":"false"},{"command":"livePreview.start.internalPreview.atFile","when":"editorLangId == html && !notebookEditorFocused","group":"1_livepreview"},{"command":"livePreview.start.externalPreview.atFile","when":"editorLangId == html && !notebookEditorFocused","group":"1_livepreview"},{"command":"livePreview.start.externalPreview.atFile","when":"activeWebviewPanelId == 'browserPreview'","group":"1_livepreview"},{"command":"livePreview.start.externalDebugPreview.atFile","when":"editorLangId == html && !notebookEditorFocused","group":"1_livepreview"},{"command":"livePreview.start.externalDebugPreview.atFile","when":"activeWebviewPanelId == 'browserPreview'","gro